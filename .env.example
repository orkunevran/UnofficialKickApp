# Unofficial Kick App — Environment Configuration
# Copy to .env and customize: cp .env.example .env

# ── Application ─────────────────────────────────────────────────────────
FLASK_DEBUG=False
PORT=8081
LOG_LEVEL=INFO
DEFAULT_LANGUAGE_CODE=en
# LOG_FORMAT_JSON=False          # Set True for structured log aggregation

# ── Kick API ────────────────────────────────────────────────────────────
KICK_API_BASE_URL=https://kick.com/api/v2/channels/
KICK_FEATURED_LIVESTREAMS_URL=https://kick.com/stream/featured-livestreams/
KICK_ALL_LIVESTREAMS_URL=https://kick.com/stream/livestreams/

# ── Cache ───────────────────────────────────────────────────────────────
CACHE_DEFAULT_TIMEOUT=300
CACHE_MAX_SIZE=2000
LIVE_CACHE_DURATION_SECONDS=30
VOD_CACHE_DURATION_SECONDS=300
FEATURED_CACHE_DURATION_SECONDS=120
FEATURED_STALE_TTL_SECONDS=300
SEARCH_CACHE_DURATION_SECONDS=30
AVATAR_CACHE_DURATION_SECONDS=604800
VIEWER_CACHE_DURATION_SECONDS=30
NEGATIVE_CACHE_DURATION_SECONDS=10

# ── Circuit Breaker ─────────────────────────────────────────────────────
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_SECONDS=30

# ── Security & CORS ─────────────────────────────────────────────────────
SECURITY_HEADERS_ENABLED=True
# CORS_ORIGINS=http://localhost:3000   # Comma-separated origins (empty = disabled)
# CORS_ALLOW_CREDENTIALS=False

# ── Async ───────────────────────────────────────────────────────────────
# ASYNCIO_THREAD_WORKERS=0      # 0 = Python default thread pool size

# ── Chromecast ──────────────────────────────────────────────────────────
CHROMECAST_SCAN_TIMEOUT=5
CHROMECAST_SELECT_MAX_RETRIES=2
CHROMECAST_SELECT_RETRY_DELAY=2
CHROMECAST_MAX_CONNECTION_FAILURES=3
CHROMECAST_DEVICE_CACHE_SECONDS=30
CHROMECAST_STOP_WAIT_SECONDS=2.0
CHROMECAST_PERIODIC_SCAN_INTERVAL=90
CHROMECAST_FALLBACK_SCAN_ENABLED=True
# CHROMECAST_FALLBACK_SCAN_SUBNETS=   # Defaults to 192.168.0.0/24,192.168.1.0/24,...
CHROMECAST_FALLBACK_SCAN_WORKERS=96
CHROMECAST_FALLBACK_SCAN_PROBE_TIMEOUT=0.25
CHROMECAST_FALLBACK_DEVICE_INFO_TIMEOUT=3.0
