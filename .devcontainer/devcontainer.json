{
  "name": "udi-ubi9-dev",
  "image": "quay.io/devfile/universal-developer-image:ubi9-latest",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {}
  },
  "forwardPorts": [8000, 3000],

  // 👇 Add these two lines
  "runArgs": ["--network=host", "--cap-add=NET_RAW", "--cap-add=NET_ADMIN"],
  "privileged": true,

  "postCreateCommand": "echo 'Happy coding 🐳'"
}